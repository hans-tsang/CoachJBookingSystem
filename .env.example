DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB?sslmode=require"
ADMIN_PASSWORD_INITIAL="change-me-on-first-login"
SESSION_SECRET="generate-32-byte-random-string-here-please"
# Gmail SMTP credentials. `gmail` is the Google account login (full address);
# `apppassword` is a Google App Password (NOT the regular account password).
# See https://myaccount.google.com/apppasswords. If unset, emails are logged
# to stdout instead of sent.
gmail=""
apppassword=""
EMAIL_FROM="HYROX <bookings@chillwithhans.com>"
OWNER_EMAIL="hanstsang@gmail.com"
PUBLIC_BASE_URL="https://hyrox.chillwithhans.com"
# IANA timezone used to anchor the default "bookings close at" (midnight at
# the start of the training day in this timezone). Optional; defaults to
# Asia/Shanghai when unset.
BOOKINGS_TIMEZONE="Asia/Shanghai"
