// Coach J Bookings — Prisma schema
// Multi-session booking system: each Session groups its own slots, fees,
// location, date, and booking-window settings.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Setting {
  key   String @id
  value String
}

// Settings keys used at runtime:
// - adminPasswordHash  : bcrypt hash
// - siteName           : optional display name (defaults to "Coach J Bookings")

model Session {
  id         String   @id @default(cuid())
  name       String
  location   String
  date       DateTime
  coachFee   Int
  gymFee     Int
  openAt     DateTime?
  closeAt    DateTime?
  isArchived Boolean  @default(false)
  slots      Slot[]
  createdAt  DateTime @default(now())

  @@index([isArchived, date])
}

model Slot {
  id        String    @id @default(cuid())
  sessionId String
  session   Session   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  date      DateTime
  time      String
  capacity  Int
  order     Int
  bookings  Booking[]
  createdAt DateTime  @default(now())

  @@unique([sessionId, time])
  @@index([sessionId, order])
}

// Booking statuses (stored as string): "Confirmed" | "Waitlist" | "Cancelled"
// Payment methods (stored as string):   "PayMe" | "FPS" | "Cash" | "Other"

model Booking {
  id        String   @id @default(cuid())
  slotId    String
  slot      Slot     @relation(fields: [slotId], references: [id], onDelete: Cascade)
  name      String
  whatsapp  String
  email     String?
  uber      Boolean  @default(false)
  payment   String   @default("PayMe")
  amount    Int?
  paid      Boolean  @default(false)
  status    String   @default("Confirmed")
  note      String?
  createdAt DateTime @default(now())

  @@index([slotId, status, createdAt])
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  payload   String
  createdAt DateTime @default(now())
}
